---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Saachi K Gupta" showHero={true}>
  <style>
    .home-intro {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.65fr);
      gap: 48px;
      align-items: start;
      margin-bottom: 52px;
    }

    .kicker {
      margin: 0 0 12px;
      color: var(--accent-strong);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .lede {
      max-width: 12ch;
    }

    .summary {
      margin-top: 10px;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.7;
    }

    .signal {
      border-left: 3px solid var(--accent);
      padding-left: 18px;
      color: var(--muted);
      font-size: 0.98rem;
    }

    .section-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }

    .section-card {
      min-height: 220px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--card);
      padding: 22px;
      color: var(--text);
      text-decoration: none;
      transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }

    .section-card:hover {
      border-color: rgba(63, 95, 74, 0.46);
      box-shadow: 0 16px 34px rgba(31, 28, 24, 0.08);
      transform: translateY(-2px);
      text-decoration: none;
    }

    .section-card h2 {
      margin: 0 0 12px;
      font-size: clamp(1.6rem, 4vw, 2.45rem);
      line-height: 1;
    }

    .section-card p {
      color: var(--muted);
    }

    .topics {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 20px;
    }

    .topics span {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 5px 10px;
      color: var(--accent-strong);
      font-size: 0.78rem;
      font-weight: 650;
    }

    @media (max-width: 760px) {
      .home-intro,
      .section-grid {
        grid-template-columns: 1fr;
      }

      .home-intro {
        gap: 24px;
      }

      .lede {
        max-width: 100%;
      }
    }
  </style>

  <section class="home-intro">
    <div>
      <p class="kicker">Strategy operator, builder, outdoor person</p>
      <h1 class="lede">Saachi K. Gupta</h1>
      <p class="summary">
        I work on ambiguous, cross-functional problems where strategy, finance, partnerships, and execution all have to hold together.
      </p>
    </div>
    <aside class="signal">
      <p>
        I can create the model and read the room. This site is a cleaner map of the work I do, the tools I am building, the adventures that keep me honest, and the writing I want to keep around.
      </p>
    </aside>
  </section>

  <section class="section-grid" aria-label="Site sections">
    <a class="section-card" href="/work">
      <h2>Work</h2>
      <p>Commercial strategy, financial rigor, partnerships, and operations at scale.</p>
      <div class="topics">
        <span>Strategy</span>
        <span>Finance</span>
        <span>Partnerships</span>
        <span>Operations</span>
      </div>
    </a>

    <a class="section-card" href="/builds">
      <h2>Builds</h2>
      <p>Tools, experiments, and AI workflows that start as curiosity and turn into something usable.</p>
      <div class="topics">
        <span>Tools</span>
        <span>Experiments</span>
        <span>AI workflows</span>
      </div>
    </a>

    <a class="section-card" href="/adventures">
      <h2>Adventures</h2>
      <p>SheJumps, triathlon training, backpacking, scuba, and the notes that come from moving through the world.</p>
      <div class="topics">
        <span>SheJumps</span>
        <span>Triathlon</span>
        <span>Backpacking</span>
        <span>Scuba</span>
      </div>
    </a>

    <a class="section-card" href="/reflections">
      <h2>Writing</h2>
      <p>The more personal archive: reflections, short notes, and things I am still working through.</p>
      <div class="topics">
        <span>Reflections</span>
        <span>Notes</span>
        <span>Archive</span>
      </div>
    </a>
  </section>
</SiteLayout>
