---
import SiteLayout from "../../layouts/SiteLayout.astro";

export const title = "Q1 Goals Bingo: Staying Intentional Through a Seattle Winter";
export const date = "2026-02-25";
export const excerpt =
  "Seattle winters can turn into inertia fast. So I made a bingo board — not productivity bingo, joy bingo — and started treating the winter as an invitation to try new things.";
export const tags = ["seattle", "intentional-living", "q1-2026"];
---

<SiteLayout title={`${title} — Saachi K Gupta`}>
  <h1>{title}</h1>
  <p style="opacity:0.7;">{date}</p>

  <p style="max-width: 75ch;">
    I love living in Washington. I love that I can be on a ferry, skiing, swimming in the lake, or at a concert all within the same day.
  </p>

  <p style="max-width: 75ch;">
    Washington winters are notoriously grey, which can be difficult. This year, ski season being...tepid....has the potential to exacerbate the gloomyness. What I DO love about WA Winters is the mild temperature - unlike where I'm from (NJ) and where I went to college (Chicago), it is _rare_ for it to be so cold outside that your face hurts (speaking from experience of chicago winters). I like that it's mild enough every day to be able to go for a walk - albeit with a jacket and sometimes a raincoat.
  </p>

  <p style="max-width: 75ch;">
    So instead of dreading winter, I made a bingo board to set a vision for Q1-2026.
  </p>

  <p style="max-width: 75ch;">
    Unlike some past Bingos (looking @ u, corporate speak zoom bingo in 2020...) this is purely for joy.
  </p>

  <figure style="margin: 0;">
    <img
      src="/images/bingo.jpeg"
      alt="Handwritten 2026 bingo board with squares for skiing, swimming, biking, parks, and Seattle adventures"
      onclick="document.getElementById('bingo-lightbox').showModal()"
      style="width: 100%; max-width: 75ch; aspect-ratio: 3/4; object-fit: cover; border-radius: 10px; border: 1px solid rgba(0,0,0,0.10); display: block; cursor: zoom-in;"
    />
    <figcaption style="margin-top: 8px; font-size: 13px; color: rgba(0,0,0,0.55); max-width: 75ch;">The 2026 board. Diagonal lines mean a bingo. Tally marks are for the squares I keep coming back to — tracking consistency, not just completion.</figcaption>
  </figure>

  <dialog id="bingo-lightbox" onclick="this.close()" style="padding: 0; border: none; border-radius: 12px; background: transparent; max-width: 90vw; max-height: 90vh;">
    <img src="/images/bingo.jpeg" alt="Bingo board full size" style="display: block; max-width: 90vw; max-height: 90vh; border-radius: 12px;" />
  </dialog>

  <h2 style="margin-top: 28px;">The Full Board</h2>
  <p style="max-width: 75ch; font-size: 13px; opacity: 0.7;">Click a green square to see what happened.</p>

  <style>
    #bingo-lightbox::backdrop { background: rgba(0,0,0,0.7); }

    .bingo-grid {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      gap: 3px;
      margin-top: 14px;
      max-width: 700px;
      font-size: 11px;
      line-height: 1.25;
    }
    .bingo-cell {
      padding: 6px 4px;
      text-align: center;
      border: 1px solid rgba(0,0,0,0.10);
      border-radius: 4px;
      background: white;
      color: inherit;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      font-size: 11px;
      font-family: inherit;
    }
    button.bingo-cell { cursor: pointer; }
    .bingo-cell.linked { background: rgba(34, 197, 94, 0.10); }
    .bingo-cell.linked:hover {
      background: rgba(34, 197, 94, 0.22);
      transform: translateY(-1px);
      transition: all 0.15s ease;
    }
    .bingo-cell.linked.active {
      background: rgba(34, 197, 94, 0.30);
      outline: 2px solid rgba(34, 197, 94, 0.5);
    }
    #blurb-panel {
      display: none;
      margin-top: 12px;
      max-width: 700px;
      padding: 18px 20px;
      border: 1px solid rgba(34, 197, 94, 0.3);
      border-radius: 10px;
      background: rgba(34, 197, 94, 0.05);
      position: relative;
    }
    #blurb-panel h3 { margin: 0 0 8px 0; font-size: 15px; }
    #blurb-panel p { margin: 0 0 12px 0; font-size: 14px; line-height: 1.5; max-width: 60ch; }
    #blurb-links { display: flex; gap: 10px; flex-wrap: wrap; }
    .blurb-link { font-size: 13px; color: black; text-decoration: underline; text-underline-offset: 2px; }
    .blurb-link:hover { opacity: 0.6; }
    #blurb-close {
      position: absolute;
      top: 12px;
      right: 14px;
      background: none;
      border: none;
      font-size: 18px;
      cursor: pointer;
      opacity: 0.4;
      line-height: 1;
      font-family: inherit;
    }
    #blurb-close:hover { opacity: 0.8; }
  </style>

  <div class="bingo-grid">
    <button class="bingo-cell linked" data-blurb="snoqualmie-ski">Snoqualmie Ski</button>
    <div class="bingo-cell">Snowshoe Artists Point</div>
    <button class="bingo-cell linked" data-blurb="seattle-art-museum">Seattle Art Museum</button>
    <div class="bingo-cell">Walk 1M</div>
    <div class="bingo-cell">Swim 3K</div>
    <div class="bingo-cell">Pure Barre</div>
    <div class="bingo-cell">Ski a Weekday</div>
    <div class="bingo-cell">Bike 5M</div>

    <button class="bingo-cell linked" data-blurb="snoqualmie-ski">Snoqualmie Ski</button>
    <div class="bingo-cell">Tuli Lodge</div>
    <div class="bingo-cell">Walk 4M</div>
    <button class="bingo-cell linked" data-blurb="snoqualmie-ski">Snoqualmie Ski</button>
    <div class="bingo-cell">Green Lake</div>
    <div class="bingo-cell">Gasworks Park</div>
    <button class="bingo-cell linked" data-blurb="ski-whistler">Ski Whistler</button>
    <div class="bingo-cell">MOOV Seattle</div>

    <div class="bingo-cell">Seattle Bouldering Project</div>
    <div class="bingo-cell">XC Ski</div>
    <div class="bingo-cell">Swim 2K</div>
    <div class="bingo-cell">Tacoma Art Museum</div>
    <div class="bingo-cell">Bike 10M</div>
    <div class="bingo-cell">Bike 20M</div>
    <div class="bingo-cell">Local Legend</div>
    <div class="bingo-cell">Go on a date</div>

    <div class="bingo-cell">Walk 5M</div>
    <div class="bingo-cell">Kerry Park</div>
    <div class="bingo-cell">Tuli Lodge</div>
    <button class="bingo-cell linked" data-blurb="swim-1k">Swim 1K</button>
    <div class="bingo-cell">Snoqualmie Day</div>
    <div class="bingo-cell">Walk Ice</div>
    <div class="bingo-cell">Honest Hours</div>
    <div class="bingo-cell">$0 Day</div>

    <div class="bingo-cell">Drip Yoga</div>
    <div class="bingo-cell">Bike 50K</div>
    <div class="bingo-cell">Club Pilates</div>
    <div class="bingo-cell">Olympic Sculpture Park</div>
    <div class="bingo-cell">Orange Theory</div>
    <div class="bingo-cell">Liftonic</div>
    <button class="bingo-cell linked" data-blurb="walk-2m">Walk 2M</button>
    <div class="bingo-cell">Swim 2M</div>

    <div class="bingo-cell">Tuli Lodge</div>
    <button class="bingo-cell linked" data-blurb="tulips">Tulips</button>
    <button class="bingo-cell linked" data-blurb="bainbridge">Bainbridge Island</button>
    <div class="bingo-cell">Crystal Mtn Ski</div>
    <div class="bingo-cell">Bike 15M</div>
    <div class="bingo-cell">Carkeek Park</div>
    <div class="bingo-cell">Snoqualmie Day</div>
    <div class="bingo-cell">San Juan Island</div>

    <div class="bingo-cell">Snowshoe Paradise</div>
    <div class="bingo-cell">Tacoma Glass Museum</div>
    <div class="bingo-cell">Ballard Hearn Club Trail</div>
    <div class="bingo-cell">Walk 3M</div>
    <div class="bingo-cell">Tuli Lodge</div>
    <button class="bingo-cell linked" data-blurb="discovery-park">Discovery Park</button>
    <div class="bingo-cell">Embroidery Project</div>
    <button class="bingo-cell linked" data-blurb="seattle-art-museum">Seattle Art Museum</button>

    <div class="bingo-cell">Magnuson Park</div>
    <div class="bingo-cell">Snoqualmie Day</div>
    <div class="bingo-cell">Bike 25M</div>
    <div class="bingo-cell">Seward Park</div>
    <div class="bingo-cell">Swim 1M</div>
    <div class="bingo-cell">Frye Art Museum</div>
    <div class="bingo-cell">Carkeek Park</div>
    <button class="bingo-cell linked" data-blurb="ski-bend">Ski Bend</button>
  </div>

  <div id="blurb-panel">
    <button id="blurb-close">×</button>
    <h3 id="blurb-title"></h3>
    <p id="blurb-text"></p>
    <div id="blurb-links"></div>
  </div>

  <script is:inline>
    const blurbs = {
      'snoqualmie-ski': {
        title: 'Snoqualmie Ski',
        text: 'My home mountain this season — skied Snoqualmie multiple times as part of the SheJumps Ikon Pass scholarship. First turns, technique work, and getting comfortable again after years away.',
        link: { href: '/adventures/shejumps-ikon-pass', label: 'Read the full ski season →' }
      },
      'ski-whistler': {
        title: 'Ski Whistler',
        text: 'Season closer at Whistler with friends. A new mountain to add to the list — more about the people than the turns.',
        link: { href: '/adventures/shejumps-ikon-pass', label: 'Read the full ski season →' }
      },
      'ski-bend': {
        title: 'Ski Bend — Mt. Bachelor',
        text: 'Kept up with friends on blues and knew when I was done for the day. That was the whole goal going into the season.',
        link: { href: '/adventures/shejumps-ikon-pass', label: 'Read the full ski season →' },
        tiktok: 'https://www.tiktok.com/@s_k_g_8/video/7618825820856995102'
      },
      'tulips': {
        title: 'Tulips — Skagit Valley',
        text: 'Third year in a row at the tulip fields. This time we actually planned around it — post Tour de Lopez, we stayed for it instead of treating it as a side trip.',
        link: { href: '/reflections/wa-tulip-season', label: 'Read the tulip post →' }
      },
      'bainbridge': {
        title: 'Bainbridge Island',
        text: 'Ferry day trip with Hannah after her sabbatical — ferry ride, long walk, great Italian food at Via Rosa. One of the best low-key days of the quarter.',
        link: { href: '/reflections/february-2026', label: 'Read February 2026 →' },
        tiktok: 'https://www.tiktok.com/@s_k_g_8/video/7614416199681674527'
      },
      'seattle-art-museum': {
        title: 'Seattle Art Museum',
        text: 'Went with the Wharton Seattle community — a good excuse to actually go, and a nice way to reconnect with people.',
        tiktok: 'https://www.tiktok.com/@s_k_g_8/video/7614003982008143135'
      },
      'walk-2m': {
        title: 'Walk 2M',
        text: 'A two-mile walk through the neighborhood. One of the tally-mark squares — came back to it a lot.',
        tiktok: 'https://www.tiktok.com/@s_k_g_8/video/7616127832619617567'
      },
      'swim-1k': {
        title: 'Swim 1K',
        text: 'Back in the pool.',
        tiktok: 'https://www.tiktok.com/@s_k_g_8/video/7624405647328578847'
      },
      'discovery-park': {
        title: 'Discovery Park',
        text: 'Bluffs, beach, forest, lighthouse — all in one park. Worth the trek every time.',
        tiktok: 'https://www.tiktok.com/@s_k_g_8/video/7613253855433870622'
      }
    };

    const panel = document.getElementById('blurb-panel');
    const titleEl = document.getElementById('blurb-title');
    const textEl = document.getElementById('blurb-text');
    const linksEl = document.getElementById('blurb-links');

    document.querySelectorAll('button.bingo-cell.linked').forEach(btn => {
      btn.addEventListener('click', () => {
        const blurb = blurbs[btn.dataset.blurb];
        if (!blurb) return;

        titleEl.textContent = blurb.title;
        textEl.textContent = blurb.text;
        linksEl.innerHTML = '';
        if (blurb.link) {
          linksEl.innerHTML += `<a href="${blurb.link.href}" class="blurb-link">${blurb.link.label}</a>`;
        }
        if (blurb.tiktok) {
          linksEl.innerHTML += `<a href="${blurb.tiktok}" target="_blank" rel="noopener" class="blurb-link">Watch on TikTok →</a>`;
        }

        panel.style.display = 'block';
        document.querySelectorAll('button.bingo-cell.linked').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    document.getElementById('blurb-close').addEventListener('click', () => {
      panel.style.display = 'none';
      document.querySelectorAll('button.bingo-cell.linked').forEach(c => c.classList.remove('active'));
    });
  </script>

</SiteLayout>
