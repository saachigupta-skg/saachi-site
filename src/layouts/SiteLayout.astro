---
const { title = "Saachi K Gupta", showHero = false, description = "", ogImage = "" } = Astro.props;
const siteUrl = Astro.url.origin;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />}
    <style>
      :root {
        --bg: #f7f2e8;
        --bg-soft: #efe7d8;
        --text: #1f1c18;
        --muted: rgba(31, 28, 24, 0.68);
        --line: rgba(31, 28, 24, 0.14);
        --accent: #3f5f4a;
        --accent-strong: #2f4938;
        --card: rgba(255, 252, 246, 0.72);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--text);
        background:
          linear-gradient(180deg, rgba(255, 252, 246, 0.68), rgba(247, 242, 232, 0) 360px),
          var(--bg);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding: 22px 40px;
        border-bottom: 1px solid var(--line);
      }

      .name {
        color: var(--text);
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(24px, 3vw, 40px);
        font-weight: 500;
        letter-spacing: 0;
        text-decoration: none;
      }
      .name:hover {
        color: var(--accent-strong);
      }

      .hero img {
        width: 100%;
        height: min(72vh, 720px);
        object-fit: cover;
        display: block;
      }

      nav.icons {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 20px;
        flex-wrap: wrap;
      }

      nav.icons a {
        color: var(--text);
        display: flex;
        align-items: center;
        text-decoration: none;
        text-underline-offset: 4px;
      }

      nav.icons a:hover {
        color: var(--accent-strong);
        text-decoration: underline;
      }

      nav.icons .home {
        font-size: 15px;
      }

      main {
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        padding: 48px 40px 64px;
        font-size: 16px;
        line-height: 1.65;
      }

      main h1 {
        margin: 0 0 14px;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.4rem, 6vw, 5rem);
        font-weight: 500;
        line-height: 0.98;
        letter-spacing: 0;
      }

      main h2 {
        margin: 28px 0 12px;
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 500;
        line-height: 1.25;
      }

      main p {
        margin: 0 0 14px;
      }

      main a {
        color: var(--accent-strong);
        text-underline-offset: 4px;
      }

      main img {
        display: block;
        width: 100%;
        max-width: 100%;
        height: auto;
      }

      main figure {
        margin: 16px 0 22px;
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--card);
        box-shadow: 0 10px 28px rgba(31, 28, 24, 0.08);
      }

      main figure + figure {
        margin-top: 16px;
      }

      main figure img {
        border-radius: 6px;
        box-shadow: none;
      }

      main figcaption {
        margin-top: 10px;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.4;
      }

      footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
        padding: 28px 40px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 14px;
      }

      .socials {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }

      .socials a {
        color: var(--muted);
        text-decoration: none;
        text-underline-offset: 4px;
      }

      .socials a:hover {
        color: var(--accent-strong);
        text-decoration: underline;
      }

      @media (max-width: 640px) {
        header {
          align-items: flex-start;
          flex-direction: column;
          gap: 14px;
          padding: 16px 18px;
        }

        .hero img {
          height: 55vh;
        }

        nav.icons {
          justify-content: flex-start;
          gap: 12px 16px;
        }

        nav.icons .home {
          font-size: 14px;
        }

        main {
          padding: 32px 18px 48px;
        }

        footer {
          align-items: flex-start;
          flex-direction: column;
          padding: 24px 18px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <a href="/" class="name">Saachi K. Gupta</a>

      <nav class="icons">
        <a href="/" class="home">Home</a>
        <a href="/work" class="home">About</a>
        <a href="/builds" class="home">Builds</a>
        <a href="/learnings" class="home">Learnings</a>
        <a href="/adventures" class="home">Adventures</a>
        <a href="/reflections" class="home">Writing</a>
      </nav>
    </header>

    {showHero && (
      <section class="hero">
        <img src="/hero.jpg" alt="Mountain landscape" />
      </section>
    )}

    <main>
      <slot />
    </main>

    <footer>
      <span>Saachi K. Gupta</span>
      <div class="socials">
        <a href="https://www.linkedin.com/in/saachi-gupta/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://twitter.com/s44ch1" target="_blank" rel="noopener noreferrer">Twitter</a>
        <a href="mailto:saachikgupta@gmail.com">Email</a>
        <a href="https://www.strava.com/athletes/63375829" target="_blank" rel="noopener noreferrer">Strava</a>
        <a href="https://www.instagram.com/s44ch1" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://health.saachigupta.net" target="_blank" rel="noopener noreferrer">Sanjay</a>
      </div>
    </footer>
  </body>
</html>
